# Parix environment

# Anthropic Claude API key (for v0.2 LLM planning)
ANTHROPIC_API_KEY=

# OpenAI API key (for OpenAI-compatible planning and fallback)
OPENAI_API_KEY=

# Optional account-auth token fallback if keychain storage is unavailable
OPENAI_ACCOUNT_AUTH_TOKEN=
ANTHROPIC_ACCOUNT_AUTH_TOKEN=
GEMINI_ACCOUNT_AUTH_TOKEN=
GROQ_ACCOUNT_AUTH_TOKEN=
GROK_ACCOUNT_AUTH_TOKEN=
PERPLEXITY_ACCOUNT_AUTH_TOKEN=
MISTRAL_ACCOUNT_AUTH_TOKEN=
KIMI_ACCOUNT_AUTH_TOKEN=
OPENROUTER_ACCOUNT_AUTH_TOKEN=
BYTEZ_ACCOUNT_AUTH_TOKEN=
COPILOT_ACCOUNT_AUTH_TOKEN=
DEEPSEEK_ACCOUNT_AUTH_TOKEN=

# Google Gemini API key (for Gemini planning and fallback)
GEMINI_API_KEY=

# Groq API key (for fast LLM fallback)
GROQ_API_KEY=

# xAI Grok API key
XAI_API_KEY=
GROK_API_KEY=

# Perplexity Sonar API key
PERPLEXITY_API_KEY=

# Mistral/Codestral API key
MISTRAL_API_KEY=

# Kimi/Moonshot API key
KIMI_API_KEY=
MOONSHOT_API_KEY=

# OpenRouter API key
OPENROUTER_API_KEY=

# Bytez API key
BYTEZ_API_KEY=

# GitHub token for Copilot-compatible auth fallback
GITHUB_TOKEN=
COPILOT_API_KEY=

# DeepSeek API key
DEEPSEEK_API_KEY=

# Local Ollama server URL (defaults to http://localhost:11434 when unset)
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Local LM Studio OpenAI-compatible URL (defaults to http://localhost:1234/v1 when unset)
LMSTUDIO_BASE_URL=
LMSTUDIO_API_KEY=
LMSTUDIO_MODEL=

# Telegram bot token (enables Telegram notifications)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for Parix notifications
TELEGRAM_CHAT_ID=

# Generic webhook URL for notification delivery
PARIX_WEBHOOK_URL=

# Discord Bot API + Gateway
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_DEFAULT_CHANNEL_ID=

# Slack Bolt app
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_DEFAULT_CHANNEL_ID=

# Microsoft Teams Bot Framework
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
TEAMS_DEFAULT_CONVERSATION_ID=

# Google Chat webhook
GOOGLE_CHAT_WEBHOOK_URL=

# WhatsApp via Baileys QR pairing
WHATSAPP_SESSION_DIR=
WHATSAPP_DEFAULT_JID=

# Signal via signal-cli
SIGNAL_CLI_PATH=
SIGNAL_ACCOUNT=
SIGNAL_DEFAULT_RECIPIENT=

# Matrix
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_DEFAULT_ROOM_ID=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_DEFAULT_USER_ID=

# Feishu/Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_CHAT_ID=

# Mattermost
MATTERMOST_URL=
MATTERMOST_BOT_TOKEN=
MATTERMOST_DEFAULT_CHANNEL_ID=

# Nextcloud Talk
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_TALK_TOKEN=

# IRC
IRC_SERVER=
IRC_PORT=
IRC_NICK=
IRC_CHANNELS=
IRC_ALLOWLIST=

# Nostr
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=
NOSTR_DEFAULT_PUBKEY=

# Synology Chat
SYNOLOGY_CHAT_WEBHOOK_URL=
SYNOLOGY_CHAT_INCOMING_TOKEN=

# Tlon / Urbit
TLON_SHIP_URL=
TLON_CODE=
TLON_DEFAULT_CHANNEL=

# Twitch chat
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNEL=

# Gateway WebChat
WEBCHAT_WS_URL=
WEBCHAT_SHARED_SECRET=

# iMessage bridge
IMSG_BRIDGE_URL=
IMSG_BRIDGE_TOKEN=
IMSG_DEFAULT_CHAT=

# Voice calls via Twilio or Plivo
VOICE_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
VOICE_DEFAULT_TO_NUMBER=

# WeChat iLink
WECHAT_ILINK_URL=
WECHAT_SESSION_DIR=
WECHAT_DEFAULT_USER_ID=

# QQ Bot
QQ_BOT_APP_ID=
QQ_BOT_TOKEN=
QQ_BOT_SECRET=
QQ_DEFAULT_TARGET_ID=

# Yuanbao
YUANBAO_PLUGIN_URL=
YUANBAO_TOKEN=
YUANBAO_DEFAULT_CHAT_ID=

# Zalo
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_ACCESS_TOKEN=
ZALO_DEFAULT_USER_ID=

# Zalo Personal
ZALO_PERSONAL_SESSION_DIR=
ZALO_PERSONAL_DEFAULT_THREAD_ID=

# Parix install/config directory (defaults to ~/.parix)
PARIX_HOME=

# Shared secret for the synapse WebSocket handshake. Required when hands binds
# to a non-loopback host (Docker, Kubernetes, anything except a desktop install
# on a single machine). On desktop, hands auto-generates one at
# ~/.parix/synapse-token. In containers, supply your own (e.g.
# `openssl rand -hex 32`). Both hands and atrium must see the same value.
PARIX_SYNAPSE_TOKEN=

# Set to 1 to allow hands to bind PARIX_WS_HOST to a non-loopback address.
# Containerized deploys already set this in the Dockerfile.
PARIX_ALLOW_REMOTE_SYNAPSE=

# Runtime environment: development or production
NODE_ENV=

# Accessibility poller — set to 1 to disable the AccessibilityBridge → atrium feed
PARIX_A11Y_DISABLED=
# Override the poller tick rate in seconds (default 1.0, clamped to 0.2 minimum)
PARIX_A11Y_INTERVAL_S=
# Override the snapshot mode: auto | accessibility | vision | fused
PARIX_A11Y_MODE=
# Override the Gemini Vision model used when local OCR is weak and GEMINI_API_KEY is set
PARIX_VISION_GEMINI_MODEL=
