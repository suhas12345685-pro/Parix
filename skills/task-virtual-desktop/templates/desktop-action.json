{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Virtual Desktop Action",
  "type": "object",
  "required": ["action", "timestamp"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "switch", "move_window", "close"]
    },
    "desktop_name": {
      "type": "string",
      "default": "Parix_Workspace"
    },
    "target_hwnd": {
      "type": ["integer", "null"]
    },
    "timestamp": {
      "type": "number"
    },
    "success": {
      "type": "boolean"
    }
  }
}
