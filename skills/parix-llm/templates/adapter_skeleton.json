{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLMAdapter Interface Schema",
  "description": "Schema describing the LLMAdapter interface contract for new provider implementations.",
  "type": "object",
  "required": ["name", "available", "chat"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Provider identifier (e.g. 'gemini', 'openai', 'ollama')"
    },
    "available": {
      "type": "object",
      "description": "Returns Promise<boolean> — checks if API key is set and endpoint reachable",
      "properties": {
        "returns": { "type": "string", "const": "Promise<boolean>" }
      }
    },
    "chat": {
      "type": "object",
      "description": "Send a chat completion request",
      "properties": {
        "params": {
          "type": "object",
          "properties": {
            "messages": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["role", "content"],
                "properties": {
                  "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                  "content": { "type": "string" }
                }
              }
            },
            "options": {
              "type": "object",
              "properties": {
                "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
                "maxTokens": { "type": "integer", "minimum": 1 },
                "taskType": { "type": "string" }
              }
            }
          }
        },
        "returns": {
          "type": "object",
          "properties": {
            "content": { "type": "string" },
            "usage": {
              "type": "object",
              "properties": {
                "prompt_tokens": { "type": "integer" },
                "completion_tokens": { "type": "integer" }
              }
            },
            "model": { "type": "string" }
          }
        }
      }
    }
  }
}
