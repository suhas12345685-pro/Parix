{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sensor Event",
  "description": "Schema for events emitted by sensor modules over Synapse",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "description": "Sensor event identifier",
      "examples": [
        "disk_low", "cpu_high", "memory_high", "swap_high",
        "battery_low", "long_uptime", "idle_shutdown",
        "wifi_disconnected", "wifi_reconnected", "wifi_weak_signal",
        "usb_device_connected", "usb_storage_connected",
        "app_crash", "app_hang",
        "terminal_error", "clipboard_sensitive_data",
        "silent:idle_after_error", "silent:read_without_edit"
      ]
    },
    "data": {
      "type": "object",
      "description": "Event-specific payload data",
      "additionalProperties": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Detection confidence (0.0 = noise, 1.0 = certain)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of detection"
    },
    "source": {
      "type": "string",
      "description": "Sensor module that produced this event",
      "examples": [
        "shadow_loop", "wifi_watch", "usb_watch",
        "app_crash", "terminal_error", "clipboard_watch",
        "silent_intent"
      ]
    }
  },
  "required": ["event_type", "data", "confidence", "timestamp"]
}
