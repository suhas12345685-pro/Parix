{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiskCleanupReport",
  "description": "Report generated after a disk cleanup task execution",
  "type": "object",
  "required": ["timestamp", "os", "targets_scanned", "space_freed_mb", "status"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of cleanup execution"
    },
    "os": {
      "type": "string",
      "enum": ["windows", "macos", "linux"]
    },
    "targets_scanned": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "files_removed", "bytes_freed"],
        "properties": {
          "path": { "type": "string" },
          "files_removed": { "type": "integer", "minimum": 0 },
          "bytes_freed": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "space_freed_mb": {
      "type": "number",
      "minimum": 0,
      "description": "Total space freed in megabytes"
    },
    "disk_free_before_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "disk_free_after_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "escalated"]
    },
    "escalation_reason": {
      "type": "string",
      "description": "Present only if status is 'escalated'"
    }
  }
}
