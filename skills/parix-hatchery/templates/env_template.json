{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parix .env Configuration",
  "description": "Schema for the .env file generated by the hatchery onboarding wizard.",
  "type": "object",
  "properties": {
    "GEMINI_API_KEY": {
      "type": "string",
      "description": "Google Gemini API key (recommended — free tier available)"
    },
    "OPENAI_API_KEY": {
      "type": "string",
      "description": "OpenAI API key"
    },
    "ANTHROPIC_API_KEY": {
      "type": "string",
      "description": "Anthropic Claude API key"
    },
    "GROQ_API_KEY": {
      "type": "string",
      "description": "Groq API key"
    },
    "TELEGRAM_BOT_TOKEN": {
      "type": "string",
      "description": "Telegram bot token for notifications"
    },
    "TELEGRAM_CHAT_ID": {
      "type": "string",
      "description": "Telegram chat ID for notifications"
    },
    "DISCORD_WEBHOOK_URL": {
      "type": "string",
      "format": "uri",
      "description": "Discord webhook URL for notifications"
    },
    "SLACK_BOT_TOKEN": {
      "type": "string",
      "description": "Slack bot token for notifications"
    },
    "SLACK_CHANNEL": {
      "type": "string",
      "description": "Slack channel ID for notifications"
    }
  },
  "additionalProperties": true
}
