{
  "name": "parix",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Proactive AI agent for OS automation",
  "workspaces": [
    "shared",
    "atrium",
    "aegis",
    "hatchery"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=atrium",
    "build": "npm run build --workspace=atrium",
    "test": "npm run test --workspace=atrium",
    "test:coverage": "npm run test:cover --workspace=atrium",
    "test:hands": "python -m pytest hands/tests",
    "test:hands:compile": "python -m compileall hands",
    "verify:ship": "node scripts/verify-ship.mjs",
    "hatch": "npm run onboarding",
    "onboarding": "npm run build:all && node hatchery/dist/index.js",
    "onboarding:reset": "npm run build:all && node hatchery/dist/index.js --reset",
    "onboarding:web": "npm run build:all && node hatchery/dist/index.js --web",
    "start": "node hatchery/dist/index.js --runtime start all",
    "desktop": "npm run build:all && node hatchery/dist/index.js --runtime start all && node scripts/launch-desktop.mjs",
    "desktop:dev": "npm run electron:dev --workspace=aegis",
    "desktop:package": "npm run build:all && npm run electron:package --workspace=aegis",
    "stop": "node hatchery/dist/index.js --runtime stop all",
    "restart": "node hatchery/dist/index.js --runtime restart all",
    "status": "node hatchery/dist/index.js --runtime status all",
    "start:atrium": "node hatchery/dist/index.js --runtime start atrium",
    "start:hands": "node hatchery/dist/index.js --runtime start hands",
    "start:aegis": "node hatchery/dist/index.js --runtime start aegis",
    "stop:atrium": "node hatchery/dist/index.js --runtime stop atrium",
    "stop:hands": "node hatchery/dist/index.js --runtime stop hands",
    "stop:aegis": "node hatchery/dist/index.js --runtime stop aegis",
    "restart:atrium": "node hatchery/dist/index.js --runtime restart atrium",
    "restart:hands": "node hatchery/dist/index.js --runtime restart hands",
    "restart:aegis": "node hatchery/dist/index.js --runtime restart aegis",
    "status:atrium": "node hatchery/dist/index.js --runtime status atrium",
    "status:hands": "node hatchery/dist/index.js --runtime status hands",
    "status:aegis": "node hatchery/dist/index.js --runtime status aegis",
    "lint": "eslint atrium/src aegis/src shared",
    "lint:fix": "eslint --fix atrium/src aegis/src shared",
    "format": "prettier --write atrium aegis shared",
    "test:e2e": "npx tsx scripts/test-e2e.ts",
    "coverage:badge": "npx tsx scripts/write-coverage-badge.ts",
    "build:all": "npm run build --workspace=shared && npm run build --workspace=atrium && npm run build --workspace=hatchery && cd aegis && npx vite build",
    "seed": "npx tsx scripts/seed-skills.ts",
    "skills:validate": "npx tsx scripts/validate-skill-manifests.ts"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  }
}
