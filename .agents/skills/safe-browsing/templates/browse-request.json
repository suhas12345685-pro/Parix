{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BrowseRequest",
  "type": "object",
  "required": ["url"],
  "properties": {
    "url": {"type": "string", "format": "uri"},
    "goal": {"type": "string", "description": "What to do on the page (scrape, fill form, click)"},
    "timeout_ms": {"type": "integer", "default": 15000},
    "wait_until": {
      "type": "string",
      "enum": ["domcontentloaded", "networkidle", "load", "commit"],
      "default": "domcontentloaded"
    },
    "extract": {
      "type": "string",
      "enum": ["text", "html", "screenshot"],
      "default": "text"
    }
  }
}
