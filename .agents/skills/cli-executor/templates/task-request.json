{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CLI Task Request Payload",
  "type": "object",
  "properties": {
    "argv": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Command as argv list (preferred)"
    },
    "command": {
      "type": "string",
      "description": "Command as string (parsed via shlex.split)"
    },
    "timeout": {
      "type": "integer",
      "default": 30,
      "description": "Timeout in seconds"
    },
    "cwd": {
      "type": ["string", "null"],
      "description": "Working directory"
    }
  }
}
