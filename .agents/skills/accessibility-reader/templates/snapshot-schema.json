{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AccessibilitySnapshot",
  "type": "object",
  "required": ["timestamp", "platform", "backend_used", "focused_app", "tree", "confidence"],
  "properties": {
    "timestamp": {"type": "number"},
    "platform": {"type": "string", "enum": ["windows", "macos", "linux"]},
    "backend_used": {"type": "string", "enum": ["uiautomation", "axapi", "atspi2", "vision", "fused", "none"]},
    "focused_app": {"type": "string"},
    "focused_element": {"$ref": "#/$defs/UIElement"},
    "tree": {"$ref": "#/$defs/UIElement"},
    "raw_text": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "$defs": {
    "UIElement": {
      "type": "object",
      "required": ["role", "name"],
      "properties": {
        "role": {"type": "string"},
        "name": {"type": "string"},
        "value": {"type": ["string", "null"]},
        "state": {"type": "array", "items": {"type": "string"}},
        "bounds": {
          "type": ["array", "null"],
          "items": {"type": "integer"},
          "minItems": 4,
          "maxItems": 4
        },
        "children": {"type": "array", "items": {"$ref": "#/$defs/UIElement"}},
        "source": {"type": "string"}
      }
    }
  }
}
