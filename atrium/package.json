{
  "name": "parix-atrium",
  "version": "0.2.0-alpha",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "tsc -p ../shared",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "tsc -p ../shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cover": "vitest run --coverage",
    "typecheck": "tsc -p ../shared && tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "keytar": "^7.9.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "pg": "^8.13.1",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/node": "^20.11.0",
    "@types/node-notifier": "^8.0.5",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  }
}
