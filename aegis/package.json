{
  "name": "parix-aegis",
  "version": "0.2.0-alpha",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env AEGIS_DEV_URL=http://localhost:3000 electron .",
    "electron:start": "electron .",
    "electron:package": "electron-builder --win --x64",
    "electron:package:mac": "electron-builder --mac",
    "electron:package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.13"
  },
  "build": {
    "appId": "ai.parix.aegis",
    "productName": "Parix",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons/parix.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/parix.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "electron/icons",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Parix"
    }
  }
}
